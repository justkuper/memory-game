# Google OAuth — https://console.cloud.google.com/apis/credentials
# Same Google Client ID used in the CDK stack (GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Facebook — https://developers.facebook.com/apps
# Same App ID used in the CDK stack (FACEBOOK_APP_ID)
VITE_FACEBOOK_APP_ID=your-facebook-app-id

# Your frontend URL
VITE_APP_URL=http://localhost:5173

# Optional: API Gateway URL once you add Lambda to the CDK stack
# VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# Cognito (for future direct SDK use — not required for current auth flow)
# VITE_COGNITO_REGION=us-east-1
# VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_COGNITO_DOMAIN=https://vocab-game-auth.auth.us-east-1.amazoncognito.com
